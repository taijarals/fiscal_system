# Copie este arquivo para .streamlit/secrets.toml e preencha com os dados do Supabase.
# Use preferencialmente a anon public key se as políticas RLS permitirem a operação.

SUPABASE_URL = "https://seu-projeto.supabase.co"
SUPABASE_KEY = "sua-chave-supabase"

# Também é aceito o formato abaixo:
# [supabase]
# url = "https://seu-projeto.supabase.co"
# key = "sua-chave-supabase"
